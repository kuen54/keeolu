# Cloudflare Pages response headers.
# Framer assets have content-hashed filenames, so they can be cached forever —
# this is what makes repeat visits and cross-page navigation feel instant (fonts,
# images, videos, logos are reused straight from disk instead of re-fetched).
/assets/images/*
  Cache-Control: public, max-age=31536000, immutable
/assets/videos/*
  Cache-Control: public, max-age=31536000, immutable
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
/assets/media/*
  Cache-Control: public, max-age=31536000, immutable

# Our hand-written runtime uses stable names — revalidate hourly so fixes ship.
/assets/framer-shim.js
  Cache-Control: public, max-age=3600
/assets/shim.css
  Cache-Control: public, max-age=3600
